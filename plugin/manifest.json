{
  "manifest_version": 3,
  "name": "Awesome Stars",
  "version": "0.1.0",
  "description": "Open GitHub repositories in Awesome Stars to render markdown lists with live stars, forks, and activity badges.",
  "icons": {
    "16": "images/awesome-stars.svg",
    "32": "images/awesome-stars.svg",
    "48": "images/awesome-stars.svg",
    "128": "images/awesome-stars.svg"
  },
  "host_permissions": [
    "*://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://github.com/*/*"
      ],
      "js": [
        "awesome-stars.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
